FoamFile
{
  version     2.0;
  format      ascii;
  class       dictionary;
  object      laplacianSmoothDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

#include "meshdata"

preserveBoundaryLayer #calc "$t_BL";
boundaryNormalPatches ();
iters 20;
smoothFactor 1;


constrainedPoints
  (

    {
      type patch;
      patch outlet;
      constraintType fixed;
    }

    {
      type patch;
      patch gas_to_liquid;
      constraintType fixed;
    }

    {
      type patch;
      patch liquid_to_gas;
      constraintType fixed;
    }

    {
      type patch;
      patch gas_to_metal;
      constraintType fixed;
    }

    {
      type patch;
      patch liquid_to_metal;
      constraintType fixed;
    }

    {
      type patch;
      patch gas_to_lid;
      constraintType fixed;
    }

    {
      type patch;
      patch $patch_name_pos;
      constraintType constDir;
      direction $wedge_pos_normal;
    }

    {
      type patch;
      patch $patch_name_neg;
      constraintType constDir;
      direction $wedge_neg_normal;
    }

    {
      type patch;
      patch symmetry;
      constraintType constDir;
      direction (-1 0 0);
    }
  );


